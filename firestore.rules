rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in user can read items and features.
    // create: auth required; createdBy must match the caller's uid; name 1–100 chars.
    // update: creator only; only imageUrl may change (name/createdBy are immutable).
    // delete: creator only (createdBy == uid).
    match /items/{itemId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.createdBy == request.auth.uid
                    && request.resource.data.name == resource.data.name
                    && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;
    }

    match /features/{featureId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.createdBy == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;
    }

    // Evaluations: any signed-in user can read.
    // create / update (own): user can write their own document; orderedItemIds must be non-empty.
    // update (cascade): any signed-in user can shrink an evaluation by exactly one item
    //   (used when an item is deleted — removes its ID from all evaluations).
    // delete: user deletes their own evaluation, OR the feature creator cascade-cleans
    //   all evaluations when deleting their feature.
    match /evaluations/{featureId}/userEvaluations/{userId} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.data.orderedItemIds is list
                            && request.resource.data.orderedItemIds.size() > 0;

      // Cascade item-deletion: shrink by exactly one entry, list may become empty.
      allow update: if request.auth != null
                    && request.resource.data.orderedItemIds is list
                    && request.resource.data.orderedItemIds.size() ==
                       resource.data.orderedItemIds.size() - 1;

      // Own delete OR feature-creator cascade delete on feature removal.
      // exists() guard prevents null-access when the feature doc was deleted first.
      allow delete: if request.auth != null
                    && (request.auth.uid == userId
                        || (exists(/databases/$(database)/documents/features/$(featureId))
                            && get(/databases/$(database)/documents/features/$(featureId))
                                 .data.createdBy == request.auth.uid));
    }
  }
}
